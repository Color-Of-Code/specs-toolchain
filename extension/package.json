{
  "name": "specs",
  "displayName": "Specs",
  "description": "VS Code support for the specs-cli framework: lint, change-requests, traceability visualisation.",
  "version": "0.3.0",
  "publisher": "jdehaan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdehaan/specs-cli.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["specs", "requirements", "traceability", "markdown"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:specs.bootstrap",
    "onView:specs.changeRequests",
    "workspaceContains:.specs.yaml",
    "workspaceContains:specs/.specs.yaml"
  ],
  "contributes": {
    "commands": [
      { "command": "specs.bootstrap", "title": "Bootstrap host…", "category": "Specs" },
      { "command": "specs.doctor", "title": "Doctor", "category": "Specs" },
      { "command": "specs.lint", "title": "Lint (all checks)", "category": "Specs" },
      { "command": "specs.lint.links", "title": "Lint: Links only", "category": "Specs" },
      { "command": "specs.lint.style", "title": "Lint: Markdown style only", "category": "Specs" },
      { "command": "specs.lint.baselines", "title": "Lint: Baselines only", "category": "Specs" },
      { "command": "specs.linkCheck", "title": "Link check (cross-references)", "category": "Specs" },
      { "command": "specs.toolsUpdate", "title": "Tools: Update cache", "category": "Specs" },
      { "command": "specs.visualize.dot", "title": "Visualize: Generate DOT", "category": "Specs" },
      { "command": "specs.visualize.mermaid", "title": "Visualize: Generate Mermaid", "category": "Specs" },
      { "command": "specs.scaffold.requirement", "title": "Scaffold: Requirement", "category": "Specs" },
      { "command": "specs.scaffold.feature", "title": "Scaffold: Feature", "category": "Specs" },
      { "command": "specs.scaffold.component", "title": "Scaffold: Component", "category": "Specs" },
      { "command": "specs.scaffold.api", "title": "Scaffold: API", "category": "Specs" },
      { "command": "specs.scaffold.service", "title": "Scaffold: Service", "category": "Specs" },
      { "command": "specs.cr.new", "title": "Change Request: New", "category": "Specs" },
      { "command": "specs.cr.status", "title": "Change Request: Status", "category": "Specs" },
      { "command": "specs.cr.drain", "title": "Change Request: Drain", "category": "Specs" },
      { "command": "specs.baseline.check", "title": "Baseline: Check", "category": "Specs" },
      { "command": "specs.baseline.update", "title": "Baseline: Update", "category": "Specs" },
      { "command": "specs.cr.refresh", "title": "Refresh CR list", "category": "Specs", "icon": "$(refresh)" },
      { "command": "specs.cr.openDir", "title": "Reveal CR folder", "category": "Specs" },
      { "command": "specs.visualize.preview", "title": "Visualize: Open preview", "category": "Specs" },
      { "command": "specs.visualize.refresh", "title": "Visualize: Refresh preview", "category": "Specs" }
    ],
    "views": {
      "specs": [
        {
          "id": "specs.changeRequests",
          "name": "Change Requests",
          "contextualTitle": "Specs"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specs",
          "title": "Specs",
          "icon": "$(book)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "specs.cr.refresh",
          "when": "view == specs.changeRequests",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "specs.cr.openDir",
          "when": "view == specs.changeRequests && viewItem == specs.cr"
        }
      ]
    },
    "configuration": {
      "title": "Specs",
      "properties": {
        "specs.useGlobalBinary": {
          "type": "boolean",
          "default": false,
          "description": "Prefer the 'specs' binary on PATH over the one bundled with the extension."
        },
        "specs.cliPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the specs CLI binary. Overrides bundled and PATH lookup."
        },
        "specs.toolsAutoUpdate": {
          "type": "boolean",
          "default": false,
          "description": "Run 'specs tools update' on activation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "lint": "tsc -p . --noEmit",
    "fetch-mermaid": "node -e \"require('https').get('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js',r=>r.pipe(require('fs').createWriteStream('media/mermaid.min.js')))\"",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
