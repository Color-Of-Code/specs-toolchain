{
  "name": "specs",
  "displayName": "Specs",
  "description": "VS Code support for the specs toolchain: lint, change-requests, traceability visualisation.",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "publisher": "Color-Of-Code",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Color-Of-Code/specs-toolchain.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "specs",
    "requirements",
    "traceability",
    "markdown"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:.specs.yaml",
    "workspaceContains:specs/.specs.yaml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "specs.bootstrap",
        "title": "Init host…",
        "category": "Specs"
      },
      {
        "command": "specs.registerFrameworks",
        "title": "Register Frameworks",
        "category": "Specs"
      },
      {
        "command": "specs.doctor",
        "title": "Doctor",
        "category": "Specs"
      },
      {
        "command": "specs.lint",
        "title": "Lint (all checks)",
        "category": "Specs"
      },
      {
        "command": "specs.lint.links",
        "title": "Lint: Links only",
        "category": "Specs"
      },
      {
        "command": "specs.lint.style",
        "title": "Lint: Markdown style only",
        "category": "Specs"
      },
      {
        "command": "specs.lint.baselines",
        "title": "Lint: Baselines only",
        "category": "Specs"
      },
      {
        "command": "specs.frameworkUpdate",
        "title": "Framework: Update cache",
        "category": "Specs"
      },
      {
        "command": "specs.visualize.dot",
        "title": "Visualize: Generate DOT",
        "category": "Specs"
      },
      {
        "command": "specs.visualize.mermaid",
        "title": "Visualize: Generate Mermaid",
        "category": "Specs"
      },
      {
        "command": "specs.scaffold.requirement",
        "title": "Scaffold: Requirement",
        "category": "Specs"
      },
      {
        "command": "specs.scaffold.feature",
        "title": "Scaffold: Feature",
        "category": "Specs"
      },
      {
        "command": "specs.scaffold.component",
        "title": "Scaffold: Component",
        "category": "Specs"
      },
      {
        "command": "specs.scaffold.api",
        "title": "Scaffold: API",
        "category": "Specs"
      },
      {
        "command": "specs.scaffold.service",
        "title": "Scaffold: Service",
        "category": "Specs"
      },
      {
        "command": "specs.cr.new",
        "title": "Change Request: New",
        "category": "Specs"
      },
      {
        "command": "specs.cr.status",
        "title": "Change Request: Status",
        "category": "Specs"
      },
      {
        "command": "specs.cr.drain",
        "title": "Change Request: Drain",
        "category": "Specs"
      },
      {
        "command": "specs.baseline.update",
        "title": "Baseline: Update",
        "category": "Specs"
      },
      {
        "command": "specs.cr.refresh",
        "title": "Refresh CR list",
        "category": "Specs",
        "icon": "$(refresh)"
      },
      {
        "command": "specs.cr.openDir",
        "title": "Reveal CR folder",
        "category": "Specs"
      },
      {
        "command": "specs.requirements.refresh",
        "title": "Refresh requirements",
        "category": "Specs",
        "icon": "$(refresh)"
      },
      {
        "command": "specs.productRequirements.refresh",
        "title": "Refresh product requirements",
        "category": "Specs",
        "icon": "$(refresh)"
      },
      {
        "command": "specs.features.refresh",
        "title": "Refresh features",
        "category": "Specs",
        "icon": "$(refresh)"
      },
      {
        "command": "specs.visualize.preview",
        "title": "Open traceability editor",
        "category": "Specs"
      },
      {
        "command": "specs.visualize.previewIcon",
        "title": "Open traceability editor",
        "category": "Specs",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "specs.visualize.refresh",
        "title": "Visualize: Refresh preview",
        "category": "Specs"
      }
    ],
    "views": {
      "specs": [
        {
          "id": "specs.changeRequests",
          "name": "Change Requests",
          "contextualTitle": "Specs"
        },
        {
          "id": "specs.productRequirements",
          "name": "Product Requirements",
          "contextualTitle": "Specs"
        },
        {
          "id": "specs.requirements",
          "name": "Requirements",
          "contextualTitle": "Specs"
        },
        {
          "id": "specs.features",
          "name": "Features",
          "contextualTitle": "Specs"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specs",
          "title": "Specs",
          "icon": "$(book)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "specs.cr.refresh",
          "when": "view == specs.changeRequests",
          "group": "navigation"
        },
        {
          "command": "specs.requirements.refresh",
          "when": "view == specs.requirements",
          "group": "navigation"
        },
        {
          "command": "specs.productRequirements.refresh",
          "when": "view == specs.productRequirements",
          "group": "navigation"
        },
        {
          "command": "specs.features.refresh",
          "when": "view == specs.features",
          "group": "navigation"
        },
        {
          "command": "specs.visualize.previewIcon",
          "when": "view == specs.changeRequests",
          "group": "navigation@10"
        },
        {
          "command": "specs.visualize.previewIcon",
          "when": "view == specs.productRequirements",
          "group": "navigation@10"
        },
        {
          "command": "specs.visualize.previewIcon",
          "when": "view == specs.requirements",
          "group": "navigation@10"
        },
        {
          "command": "specs.visualize.previewIcon",
          "when": "view == specs.features",
          "group": "navigation@10"
        }
      ],
      "view/item/context": [
        {
          "command": "specs.cr.openDir",
          "when": "view == specs.changeRequests && viewItem == specs.cr"
        }
      ]
    },
    "configuration": {
      "title": "Specs",
      "properties": {
        "specs.useGlobalBinary": {
          "type": "boolean",
          "default": false,
          "description": "Prefer the 'specs' binary on PATH over the one bundled with the extension."
        },
        "specs.enginePath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the specs engine binary. Overrides bundled and PATH lookup."
        },
        "specs.defaultFramework": {
          "type": "string",
          "default": "default",
          "markdownDescription": "Name of the framework entry to use when running `specs init`. Must match a name in `specs.frameworks` or an entry already registered in the user-level registry (`~/.config/specs/frameworks.yaml`)."
        },
        "specs.frameworks": {
          "type": "array",
          "default": [],
          "markdownDescription": "Framework entries to register with `specs framework add` when using **Specs: Register Frameworks**. Each entry maps a short name to either a remote git URL or a local path. URL-based entries may optionally pin a git ref (branch, tag, or SHA).",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Short name used to reference this framework (e.g. 'default', 'acme')."
              },
              "url": {
                "type": "string",
                "description": "Git URL of the remote framework repository. Mutually exclusive with 'path'."
              },
              "ref": {
                "type": "string",
                "description": "Git ref (branch, tag, or SHA) to pin for a URL-based entry. Defaults to 'main' when omitted."
              },
              "path": {
                "type": "string",
                "description": "Absolute or workspace-relative path to a local framework directory. Mutually exclusive with 'url'."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "node ./scripts/prepare-media.mjs && tsc -p .",
    "watch": "tsc -p . --watch",
    "lint": "tsc -p . --noEmit",
    "package": "vsce package --no-dependencies",
    "package:bundled": "node --experimental-strip-types ./scripts/build-extension.ts",
    "deploy-dev": "mkdir -p ../bin && cd ../engine/cmd/specs && go build -o ../../../bin/specs && cd ../../../extension && pnpm run compile && pnpm run symlink",
    "symlink": "node ./scripts/create-symlink.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "cytoscape": "^3.33.2",
    "typescript": "^5.4.0"
  }
}
