{
  "name": "specs-toolchain-devtools",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "Repo-level dev tooling for markdown lint/format. Not published.",
  "scripts": {
    "md:lint": "cd cli && go run ./cmd/specs lint --style",
    "md:format": "prettier --write 'docs/*.md'",
    "md:check": "prettier --check 'docs/*.md' && cd cli && go run ./cmd/specs lint --style",
    "format": "prettier --write 'docs/*.md'",
    "format:check": "prettier --check 'docs/*.md'",
    "build": "pnpm run build:cli && pnpm run build:extension",
    "build:cli": "cd cli/cmd/specs && go build -o ../../../specs",
    "build:extension": "pnpm --filter ./extension run compile",
    "package:extension": "node --experimental-strip-types ./extension/scripts/build-extension.ts",
    "deploy-dev": "pnpm --filter extension run deploy-dev"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
