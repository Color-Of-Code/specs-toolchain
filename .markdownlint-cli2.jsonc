{
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD033": false,
    "MD041": false,
  },
  "globs": ["docs/*.md"],
  "ignores": [
    "**/node_modules/**",
    "extension/out/**",
    "extension/bin/**",
    "cli/dist/**",
    "dist/**",
    "**/CHANGELOG.md",
  ],
}
